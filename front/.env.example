# Supabase connection for the SPA.
# The anon key is public by design — RLS is the authorization boundary (ADR-0001).
# For local development, copy this file to .env.local and fill in the values
# printed by `supabase start` (or `supabase status`).
# In production, Cloudflare Pages injects these at build time.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Integration tests only (setup/teardown as service_role). NOT VITE_-prefixed,
# so it never reaches the client bundle. From `supabase status` (Secret key).
SUPABASE_SECRET_KEY=your-local-secret-key
